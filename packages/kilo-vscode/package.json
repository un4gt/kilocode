{
  "name": "kilocode-lite",
  "displayName": "kilocode-- (kilocode lite)",
  "description": "Lite VS Code AI coding agent with a bundled internal runtime. Generate code from natural language, run terminal commands, manage agent worktrees, and use inline suggestions directly inside VS Code.",
  "version": "7.1.8",
  "icon": "assets/icons/logo-outline-black.png",
  "galleryBanner": {
    "color": "#FFFFFF",
    "theme": "light"
  },
  "publisher": "un4gt",
  "repository": {
    "type": "git",
    "url": "https://github.com/un4gt/kilocode.git",
    "directory": "packages/kilo-vscode"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "license": "MIT",
  "author": {
    "name": "kilocode lite"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "kilo",
    "claude",
    "dev",
    "mcp",
    "openrouter",
    "coding",
    "agent",
    "autonomous",
    "chatgpt",
    "sonnet",
    "ai",
    "llama",
    "kilocode--",
    "kilocode"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kilocode-lite-ActivityBar",
          "title": "kilocode--",
          "icon": "assets/icons/kilo-light.png",
          "darkIcon": "assets/icons/kilo-dark.png"
        }
      ]
    },
    "views": {
      "kilocode-lite-ActivityBar": [
        {
          "type": "webview",
          "id": "kilocode-lite.SidebarProvider",
          "name": "kilocode--"
        }
      ]
    },
    "commands": [
      {
        "command": "kilocode-lite.new.plusButtonClicked",
        "title": "New Task",
        "icon": "$(add)"
      },
      {
        "command": "kilocode-lite.new.agentManagerOpen",
        "title": "Agent Manager",
        "icon": "$(circuit-board)"
      },
      {
        "command": "kilocode-lite.new.marketplaceButtonClicked",
        "title": "Marketplace",
        "icon": "$(extensions)"
      },
      {
        "command": "kilocode-lite.new.historyButtonClicked",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "kilocode-lite.new.profileButtonClicked",
        "title": "Profile",
        "icon": "$(account)"
      },
      {
        "command": "kilocode-lite.new.settingsButtonClicked",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "kilocode-lite.new.openInTab",
        "title": "kilocode--",
        "icon": {
          "light": "assets/icons/kilo-light.svg",
          "dark": "assets/icons/kilo-dark.svg"
        }
      },
      {
        "command": "kilocode-lite.new.showChanges",
        "title": "Show Changes",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.openMigrationWizard",
        "title": "Migrate Settings from Legacy Version",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.autocomplete.generateSuggestions",
        "title": "Generate Suggested Edits",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.autocomplete.cancelSuggestions",
        "title": "Cancel Suggested Edits",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.previousSession",
        "title": "Agent Manager: Previous Session",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.nextSession",
        "title": "Agent Manager: Next Session",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.previousTab",
        "title": "Agent Manager: Previous Tab",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.nextTab",
        "title": "Agent Manager: Next Tab",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.showTerminal",
        "title": "Agent Manager: Focus Terminal",
        "category": "kilocode--",
        "icon": "$(terminal)"
      },
      {
        "command": "kilocode-lite.new.agentManager.toggleDiff",
        "title": "Agent Manager: Toggle Diff Panel",
        "category": "kilocode--",
        "icon": "$(diff)"
      },
      {
        "command": "kilocode-lite.new.agentManager.showShortcuts",
        "title": "Agent Manager: Show Keyboard Shortcuts",
        "category": "kilocode--",
        "icon": "$(keyboard)"
      },
      {
        "command": "kilocode-lite.new.agentManager.newTab",
        "title": "Agent Manager: New Tab",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.closeTab",
        "title": "Agent Manager: Close Tab",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.newWorktree",
        "title": "Agent Manager: New Worktree",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.openWorktree",
        "title": "Agent Manager: Open Worktree",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.closeWorktree",
        "title": "Agent Manager: Close Worktree",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.advancedWorktree",
        "title": "Agent Manager: Advanced New Worktree",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo1",
        "title": "Agent Manager: Jump to Item 1",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo2",
        "title": "Agent Manager: Jump to Item 2",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo3",
        "title": "Agent Manager: Jump to Item 3",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo4",
        "title": "Agent Manager: Jump to Item 4",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo5",
        "title": "Agent Manager: Jump to Item 5",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo6",
        "title": "Agent Manager: Jump to Item 6",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo7",
        "title": "Agent Manager: Jump to Item 7",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo8",
        "title": "Agent Manager: Jump to Item 8",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo9",
        "title": "Agent Manager: Jump to Item 9",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "kilocode--",
        "icon": {
          "light": "assets/icons/kilo-light.svg",
          "dark": "assets/icons/kilo-dark.svg"
        }
      },
      {
        "command": "kilocode-lite.new.explainCode",
        "title": "Explain Code",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.fixCode",
        "title": "Fix Code",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.improveCode",
        "title": "Improve Code",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.addToContext",
        "title": "Add to Context",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.terminalAddToContext",
        "title": "Add Terminal Content to Context",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.terminalFixCommand",
        "title": "Fix This Command",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.terminalExplainCommand",
        "title": "Explain This Command",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.focusChatInput",
        "title": "Focus Chat Input",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.cycleAgentMode",
        "title": "Cycle Agent Mode",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.cyclePreviousAgentMode",
        "title": "Cycle Previous Agent Mode",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.toggleAutoApprove",
        "title": "Toggle Auto-Approve",
        "category": "kilocode--"
      },
      {
        "command": "kilocode-lite.new.generateTerminalCommand",
        "title": "Generate Terminal Command",
        "category": "kilocode--"
      }
    ],
    "submenus": [
      {
        "id": "kilocode-lite.new.editorContextMenu",
        "label": "kilocode--"
      },
      {
        "id": "kilocode-lite.new.terminalContextMenu",
        "label": "kilocode--"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kilocode-lite.new.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == kilocode-lite.SidebarProvider"
        },
        {
          "command": "kilocode-lite.new.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == kilocode-lite.SidebarProvider"
        },
        {
          "command": "kilocode-lite.new.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == kilocode-lite.SidebarProvider"
        },
        {
          "command": "kilocode-lite.new.marketplaceButtonClicked",
          "group": "navigation@3",
          "when": "view == kilocode-lite.SidebarProvider"
        },
        {
          "command": "kilocode-lite.new.profileButtonClicked",
          "group": "navigation@4",
          "when": "view == kilocode-lite.SidebarProvider"
        },
        {
          "command": "kilocode-lite.new.settingsButtonClicked",
          "group": "navigation@5",
          "when": "view == kilocode-lite.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "kilocode-lite.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "kilocode-lite.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "kilocode-lite.new.openInTab",
          "group": "navigation",
          "when": "true"
        }
      ],
      "editor/context": [
        {
          "submenu": "kilocode-lite.new.editorContextMenu",
          "group": "1_kilocode"
        }
      ],
      "kilocode-lite.new.editorContextMenu": [
        {
          "command": "kilocode-lite.new.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "kilocode-lite.new.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "kilocode-lite.new.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "kilocode-lite.new.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "kilocode-lite.new.terminalContextMenu",
          "group": "2_kilocode"
        }
      ],
      "kilocode-lite.new.terminalContextMenu": [
        {
          "command": "kilocode-lite.new.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "kilocode-lite.new.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "kilocode-lite.new.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kilocode-lite.new.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "kilocode-lite.new.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "kilocode-lite.new.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "kilocode-lite.new.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "kilocode-lite.new.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "kilocode-lite.new.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.agentManager.jumpTo9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "activeWebviewPanelId == 'kilocode-lite.new.AgentManagerPanel'"
      },
      {
        "command": "kilocode-lite.new.cycleAgentMode",
        "key": "ctrl+.",
        "mac": "cmd+."
      },
      {
        "command": "kilocode-lite.new.cyclePreviousAgentMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+."
      },
      {
        "command": "kilocode-lite.new.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode-lite.new.autocomplete.hasSuggestions"
      },
      {
        "command": "kilocode-lite.new.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode-lite.new.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "kilocode-lite.new.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && kilocode-lite.new.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      }
    ],
    "configuration": {
      "title": "kilocode--",
      "properties": {
        "kilocode-lite.new.language": {
          "type": "string",
          "default": "",
          "description": "Override the UI language for kilocode-- (e.g. en, de, ja). Empty means use VS Code's display language.",
          "enum": [
            "",
            "en",
            "zh",
            "zht",
            "ko",
            "de",
            "es",
            "fr",
            "da",
            "ja",
            "pl",
            "ru",
            "ar",
            "no",
            "br",
            "th",
            "bs",
            "tr",
            "nl"
          ],
          "enumDescriptions": [
            "Auto (VS Code language)",
            "English",
            "简体中文",
            "繁體中文",
            "한국어",
            "Deutsch",
            "Español",
            "Français",
            "Dansk",
            "日本語",
            "Polski",
            "Русский",
            "العربية",
            "Norsk",
            "Português (Brasil)",
            "ภาษาไทย",
            "Bosanski",
            "Türkçe",
            "Nederlands"
          ]
        },
        "kilocode-lite.new.model.providerID": {
          "type": "string",
          "default": "kilo",
          "description": "Default model provider ID for new sessions"
        },
        "kilocode-lite.new.model.modelID": {
          "type": "string",
          "default": "kilo-auto/free",
          "description": "Default model ID for new sessions"
        },
        "kilocode-lite.new.autocomplete.enableAutoTrigger": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic inline completion suggestions"
        },
        "kilocode-lite.new.autocomplete.enableSmartInlineTaskKeybinding": {
          "type": "boolean",
          "default": false,
          "description": "Enable smart inline task keybinding"
        },
        "kilocode-lite.new.autocomplete.enableChatAutocomplete": {
          "type": "boolean",
          "default": false,
          "description": "Enable chat textarea autocomplete"
        },
        "kilocode-lite.new.browserAutomation.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable browser automation powered by Playwright. When enabled, the AI agent can interact with web pages in a visible Chrome window."
        },
        "kilocode-lite.new.browserAutomation.useSystemChrome": {
          "type": "boolean",
          "default": true,
          "description": "Use your system's installed Chrome browser instead of downloading a separate Chromium instance."
        },
        "kilocode-lite.new.browserAutomation.headless": {
          "type": "boolean",
          "default": false,
          "description": "Run browser automation in headless mode (no visible window). When disabled, you can watch the agent interact with the browser."
        },
        "kilocode-lite.new.notifications.agent": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when agent completes a task"
        },
        "kilocode-lite.new.notifications.permissions": {
          "type": "boolean",
          "default": true,
          "description": "Show notification on permission requests"
        },
        "kilocode-lite.new.notifications.errors": {
          "type": "boolean",
          "default": true,
          "description": "Show notification on errors"
        },
        "kilocode-lite.new.sounds.agent": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "none"
          ],
          "description": "Sound to play when agent completes"
        },
        "kilocode-lite.new.sounds.permissions": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "none"
          ],
          "description": "Sound to play on permission requests"
        },
        "kilocode-lite.new.sounds.errors": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "none"
          ],
          "description": "Sound to play on errors"
        }
      }
    }
  },
  "scripts": {
    "prepare:cli-binary": "bun script/local-bin.ts",
    "compile": "bun run prepare:cli-binary -- --force && bun run rebuild-sdk && bun run typecheck && bun run lint && node esbuild.js",
    "watch": "bun run rebuild-sdk && bun run --parallel watch:esbuild watch:tsc",
    "watch:esbuild": "bun run prepare:cli-binary && node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:cli": "bun script/watch-cli.ts",
    "package": "bun run prepare:cli-binary && bun run rebuild-sdk && bun run typecheck && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "check-types:webview": "bun script/typecheck.ts --project webview-ui/tsconfig.json",
    "typecheck": "bun run check-types:extension && bun run check-types:webview",
    "check-types:extension": "bun script/typecheck.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "check-kilocode-change": "! grep -rn 'kilocode_change' . ../kilo-ui/ --exclude='package.json' --exclude='*.md' --exclude-dir='node_modules' --exclude-dir='dist' | grep -v '`kilocode_change`'",
    "lint": "eslint src webview-ui",
    "test": "vscode-test",
    "test:unit": "bun test tests/unit/",
    "rebuild-sdk": "bun run --cwd ../sdk/js build",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build -o storybook-static",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "snapshot:build": "bun script/dev-snapshot.ts build",
    "snapshot:install": "bun script/dev-snapshot.ts install",
    "extension": "bun script/launch.ts",
    "vsix:build": "bun script/build.ts"
  },
